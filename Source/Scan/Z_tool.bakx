            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="Tdecoupling" desc="Decoupling time [s]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0.2" max="1E+308">
