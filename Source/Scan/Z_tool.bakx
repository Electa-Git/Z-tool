      <form name="Z-tool plus/minus DC scan point" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Configuration" visible="true">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
          <parameter name="f0" desc="Fundamental frequency [Hz]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="V0_peak" desc="Nominal voltage [kV]" type="Real" group="" helpmode="Append" content_type="Literal" intent="Input" dim="1" animate="false" unit="" min="1" max="5000">
            <value><![CDATA[640]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Pole-to-pole DC voltage in kV]]></help>
          </parameter>
          <parameter name="V_perturb_mag" desc="Perturbation amplitude [pu]" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[0.01]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Perturbation amplitude in per unit.]]></help>
          </parameter>
          <parameter name="T_inj" desc="Injection time [s]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0.2" max="1E+308">
            <value><![CDATA[1e8]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="selector" desc="Injection selection" type="Integer" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0" max="5">
