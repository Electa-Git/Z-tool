      <form name="Z-tool scan point" splitter="60" w="320" h="400" commentlines="4" help-width="490">
        <category name="Scan configuration" visible="true" splitter="57">
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" type="Text" group="" helpmode="Append" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Name to identify the bus.]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
          </parameter>
          <parameter name="f0" desc="Fundamental frequency [Hz]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Used to initialize the phase tracking.]]></help>
          </parameter>
          <parameter name="V0_peak" desc="Peak voltage L-G [kV]" type="Real" group="" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="0.1" max="5000">
            <value><![CDATA[179.63]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[]]></help>
          </parameter>
          <parameter name="V_perturb_mag" desc="Perturbation amplitude [pu]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[0.01]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Please, set the perturbation amplitude in per unit.]]></help>
          </parameter>
          <parameter name="T_inj" desc="Injections time [s]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0.3" max="1E+308">
            <value><![CDATA[1e8]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Automatically updated with respect to the absolute simulation time.]]></help>
          </parameter>
          <parameter name="selector" desc="Injection selection" type="Integer" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0" max="2">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Automatically updated]]></help>
          </parameter>
          <parameter name="Tdecoupling" desc="Decoupling time [s]" type="Real" group="" helpmode="Append" content_type="Constant" intent="Input" dim="1" animate="false" unit="" min="0.3" max="1E+308">
