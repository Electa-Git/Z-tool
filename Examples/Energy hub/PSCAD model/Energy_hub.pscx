      <script>
        <segment name="Dsdyn" id="1109933470" classid="CoreSegment"><![CDATA[#STORAGE LOGICAL:12 INTEGER:36 REAL:94 STOR:30 RTCI:108 RTCF:55 STXFRI:6 STXFRF:487 
#BEGIN
#LOCAL INTEGER BR_IDX
#LOCAL INTEGER ND_IDX
!
      RTCI(NRTCI) = $BRN1
      RTCI(NRTCI + 1) = $BRN2
      RTCI(NRTCI + 2) = $BRN3
      RTCI(NRTCI + 3) = $BRN4
      RTCI(NRTCI + 4) = $BRN5
      RTCI(NRTCI + 5) = $BRN6
      RTCI(NRTCI + 6) = $BRN7
      RTCI(NRTCI + 7) = $BRN8
      RTCI(NRTCI + 8) = $BRN9
      RTCI(NRTCI + 9) = $BRN10
      RTCI(NRTCI + 10) = $BRN11
      RTCI(NRTCI + 11) = $BRN12
      RTCI(NRTCI + 12) = $BRN13
      RTCI(NRTCI + 13) = $BRN14
      RTCI(NRTCI + 14) = $BRN15
      RTCI(NRTCI + 15) = $BRN16
      RTCI(NRTCI + 16) = $BRN17
      RTCI(NRTCI + 17) = $BRN18
      RTCI(NRTCI + 18) = $BRN19
      RTCI(NRTCI + 19) = $BRN20
      RTCI(NRTCI + 20) = $BRN21
      RTCI(NRTCI + 21) = $BRN22
      RTCI(NRTCI + 22) = $BRN23
      RTCI(NRTCI + 23) = $BRN24
      RTCI(NRTCI + 24) = $BRN25
      RTCI(NRTCI + 25) = $BRN26
      RTCI(NRTCI + 26) = $BRN27
      RTCI(NRTCI + 27) = $BRN28
      RTCI(NRTCI + 28) = $BRN29
      RTCI(NRTCI + 29) = $BRN30
      RTCI(NRTCI + 30) = $BRN31
!
      BR_IDX = NRTCI
      NRTCI = NRTCI + 31
!
      ND_IDX = NRTCI
      NRTCI = NRTCI + 23
!
      CALL COMPONENT_ID(ICALL_NO, $#Component)
      CALL Blackbox_MMC_Averaged_2_2Dyn_Begin($Sbase, $Vbase, $Vbase_DC,
     + $Kpq, $Kiq, $Kp, $Ki, $Kpc, $Kic, $N, $Csm, $Ltrafo_pu, $Rtrafo_pu, $KpPLL,
     + $KiPLL, $t_rst, $Vtr_pri_LL_RMS, $Vtr_sec_LL_RMS, BR_IDX, ND_IDX, ($#[1]-1),
     + $SS)
!
#ENDBEGIN
#LOCAL INTEGER BR_IDX
#LOCAL INTEGER ND_IDX
!
      IF (TIMEZERO) THEN
!
        BR_IDX = NRTCI
        NRTCI = NRTCI + 31
!
        RTCI(NRTCI) = $GND
        RTCI(NRTCI + 1) = $DCP
        RTCI(NRTCI + 2) = $DCN
        RTCI(NRTCI + 3) = $AC(1)
        RTCI(NRTCI + 4) = $AC(2)
        RTCI(NRTCI + 5) = $AC(3)
        RTCI(NRTCI + 6) = $NBBF(1)
        RTCI(NRTCI + 7) = $NBBF(2)
        RTCI(NRTCI + 8) = $NBBF(3)
        RTCI(NRTCI + 9) = $NBBF(4)
        RTCI(NRTCI + 10) = $NBBF(5)
        RTCI(NRTCI + 11) = $NBBF(6)
        RTCI(NRTCI + 12) = $NBBF(7)
        RTCI(NRTCI + 13) = $NBBF(8)
        RTCI(NRTCI + 14) = $NBBF(9)
        RTCI(NRTCI + 15) = $NBBF(10)
        RTCI(NRTCI + 16) = $NBBF(11)
        RTCI(NRTCI + 17) = $NBBF(12)
        RTCI(NRTCI + 18) = $NBBF(13)
        RTCI(NRTCI + 19) = $NBBF(14)
        RTCI(NRTCI + 20) = $NBBF(15)
        RTCI(NRTCI + 21) = $NBBF(16)
        RTCI(NRTCI + 22) = $NBBF(17)
!
        ND_IDX = NRTCI
        NRTCI = NRTCI + 23
!
      ELSE
!
        BR_IDX = NRTCI
        NRTCI = NRTCI + 31
!
        ND_IDX = NRTCI
        NRTCI = NRTCI + 23
!
      ENDIF
!
      CALL COMPONENT_ID(ICALL_NO, $#Component)
      CALL Blackbox_MMC_Averaged_2_2Dyn($Pref, $Qref, $Larm, $Rarm, $Sbase,
     + $Vbase, $Vbase_DC, $Kpp, $Kip, $Kpq, $Kiq, $Kp, $Ki, $Kpc, $Kic, $N, $Csm,
     + $Ltrafo_pu, $Rtrafo_pu, $KpPLL, $KiPLL, $t_rst, $Vtr_pri_LL_RMS, $Vtr_sec_LL_RMS,
     + BR_IDX, ND_IDX, ($#[1]-1), $SS)
!
]]></segment>
