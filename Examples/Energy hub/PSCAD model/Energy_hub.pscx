      RTCI(NRTCI + 27) = $BRN28
      RTCI(NRTCI + 28) = $BRN29
      RTCI(NRTCI + 29) = $BRN30
      RTCI(NRTCI + 30) = $BRN31
!
      BR_IDX = NRTCI
      NRTCI = NRTCI + 31
!
      ND_IDX = NRTCI
      NRTCI = NRTCI + 23
!
      CALL COMPONENT_ID(ICALL_NO, $#Component)
      CALL Blackbox_MMC_Averaged_2_2Out_Begin($Sbase, $Vbase, $Vbase_DC,
     + $Kpq, $Kiq, $Kp, $Ki, $Kpc, $Kic, $N, $Csm, $Ltrafo_pu, $Rtrafo_pu, $KpPLL,
     + $KiPLL, $t_rst, $Vtr_pri_LL_RMS, $Vtr_sec_LL_RMS, BR_IDX, ND_IDX, ($#[1]-1),
     + $SS)
!
#ENDBEGIN
#LOCAL INTEGER BR_IDX
#LOCAL INTEGER ND_IDX
!
      IF (TIMEZERO) THEN
!
        BR_IDX = NRTCI
        NRTCI = NRTCI + 31
!
        RTCI(NRTCI) = $GND
        RTCI(NRTCI + 1) = $DCP
        RTCI(NRTCI + 2) = $DCN
        RTCI(NRTCI + 3) = $AC(1)
        RTCI(NRTCI + 4) = $AC(2)
        RTCI(NRTCI + 5) = $AC(3)
        RTCI(NRTCI + 6) = $NBBF(1)
        RTCI(NRTCI + 7) = $NBBF(2)
        RTCI(NRTCI + 8) = $NBBF(3)
        RTCI(NRTCI + 9) = $NBBF(4)
        RTCI(NRTCI + 10) = $NBBF(5)
        RTCI(NRTCI + 11) = $NBBF(6)
        RTCI(NRTCI + 12) = $NBBF(7)
        RTCI(NRTCI + 13) = $NBBF(8)
        RTCI(NRTCI + 14) = $NBBF(9)
        RTCI(NRTCI + 15) = $NBBF(10)
        RTCI(NRTCI + 16) = $NBBF(11)
        RTCI(NRTCI + 17) = $NBBF(12)
        RTCI(NRTCI + 18) = $NBBF(13)
        RTCI(NRTCI + 19) = $NBBF(14)
        RTCI(NRTCI + 20) = $NBBF(15)
        RTCI(NRTCI + 21) = $NBBF(16)
        RTCI(NRTCI + 22) = $NBBF(17)
!
        ND_IDX = NRTCI
        NRTCI = NRTCI + 23
!
      ELSE
!
        BR_IDX = NRTCI
        NRTCI = NRTCI + 31
!
        ND_IDX = NRTCI
        NRTCI = NRTCI + 23
!
      ENDIF
!
      CALL COMPONENT_ID(ICALL_NO, $#Component)
      CALL Blackbox_MMC_Averaged_2_2Out(BR_IDX, ND_IDX, ($#[1]-1), $SS)
!
]]></segment>
        <segment name="Branch" id="1010664940" classid="CoreSegment"><![CDATA[BRN1 = $NBBF(17)  $NBBF(7)  AMMETER      
BRN2 = $NBBF(17)  $NBBF(8)  AMMETER      
BRN3 = $NBBF(17)  $NBBF(9)  AMMETER      
BRN4 = $NBBF(10)  $DCN  AMMETER      
BRN5 = $NBBF(11)  $DCN  AMMETER      
BRN6 = $NBBF(12)  $DCN  AMMETER      
BRN7 = $NBBF(17)  $DCP  AMMETER      
BRN8 = $NBBF(16)  $NBBF(13)  BREAKER  1.0  0.0  0.0
BRN9 = $NBBF(15)  $NBBF(13)  BREAKER  1.0  0.0  0.0
BRN10 = $NBBF(14)  $NBBF(13)  BREAKER  1.0  0.0  0.0
BRN11 = $AC(3)  $GND  BREAKER  1.0  0.0  0.0
BRN12 = $AC(2)  $GND  BREAKER  1.0  0.0  0.0
BRN13 = $AC(1)  $GND  BREAKER  1.0  0.0  0.0
BRN14 = $NBBF(1)  $NBBF(7)  SOURCE  0.0  0.0  0.0
BRN15 = $NBBF(2)  $NBBF(8)  SOURCE  0.0  0.0  0.0
BRN16 = $NBBF(3)  $NBBF(9)  SOURCE  0.0  0.0  0.0
BRN17 = $NBBF(10)  $NBBF(4)  SOURCE  0.0  0.0  0.0
BRN18 = $NBBF(11)  $NBBF(5)  SOURCE  0.0  0.0  0.0
BRN19 = $NBBF(12)  $NBBF(6)  SOURCE  0.0  0.0  0.0
BRN20 = $AC(1)  $GND    1.0  0.1  1.0
BRN21 = $AC(2)  $GND    1.0  0.1  1.0
BRN22 = $AC(3)  $GND    1.0  0.1  1.0
BRN23 = $NBBF(14)  $NBBF(13)    1.0  0.1  1.0
BRN24 = $NBBF(15)  $NBBF(13)    1.0  0.1  1.0
BRN25 = $NBBF(16)  $NBBF(13)    1.0  0.1  1.0
BRN26 = $NBBF(16)  $NBBF(6)    1.0  0.1  0.0
BRN27 = $NBBF(15)  $NBBF(5)    1.0  0.1  0.0
BRN28 = $NBBF(14)  $NBBF(4)    1.0  0.1  0.0
BRN29 = $NBBF(3)  $NBBF(16)    1.0  0.1  0.0
BRN30 = $NBBF(2)  $NBBF(15)    1.0  0.1  0.0
BRN31 = $NBBF(1)  $NBBF(14)    1.0  0.1  0.0
]]></segment>
        <segment name="Transformers" id="2030278235" classid="CoreSegment"><![CDATA[#TRANSFORMERS 3
#WINDINGS 2
C   3 Phase, 2 Winding Transformer
  -2 -1 / Number of windings...
  $AC(1) $GND    0.0 7.12 /
  $NBBF(14) $NBBF(13)    0.0 -4.11   0.0 2.38 /
 888 /
  $AC(2) $GND /
  $NBBF(15) $NBBF(13) /
 888 /
  $AC(3) $GND /
  $NBBF(16) $NBBF(13) /
C
]]></segment>
        <segment name="Matrix-Fill" id="1346317087" classid="CoreSegment"><![CDATA[$AC(1) $GND $NBBF(14) $NBBF(13)
$AC(2) $GND $NBBF(15) $NBBF(13)
$AC(3) $GND $NBBF(16) $NBBF(13)
]]></segment>
