      <script>
        <segment name="Dsdyn" id="1112833823" classid="CoreSegment"><![CDATA[#STORAGE LOGICAL:12 INTEGER:36 REAL:127 STOR:28 RTCI:166 RTCF:50 STXFRI:6 STXFRF:512 
#BEGIN
#LOCAL INTEGER BR_IDX
#LOCAL INTEGER ND_IDX
!
      RTCI(NRTCI) = $BRN1
      RTCI(NRTCI + 1) = $BRN2
      RTCI(NRTCI + 2) = $BRN3
      RTCI(NRTCI + 3) = $BRN4
      RTCI(NRTCI + 4) = $BRN5
      RTCI(NRTCI + 5) = $BRN6
      RTCI(NRTCI + 6) = $BRN7
