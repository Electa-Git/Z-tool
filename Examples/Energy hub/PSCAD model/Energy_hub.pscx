      <form name="Averaged model of the grid-side converter with constant DC voltage" splitter="60" w="389" h="624" commentlines="4" help-width="490">
        <category name="Configuration" visible="true" splitter="57">
          <parameter name="p_ref" desc="Active power [pu]" type="Real" group="Setpoints" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="-1" max="2">
            <value><![CDATA[0.5]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Per unit]]></help>
          </parameter>
          <cond><![CDATA[true]]></cond>
          <parameter name="Name" desc="Name" group="" type="Text" helpmode="Overwrite" allowemptystr="true" min="0" max="0">
            <value><![CDATA[]]></value>
            <cond><![CDATA[true]]></cond>
            <help><![CDATA[The name of the component]]></help>
            <regex><![CDATA[]]></regex>
            <error_msg><![CDATA[]]></error_msg>
            <vis />
          </parameter>
          <parameter name="V_LL_RMS" desc="Rated voltage [kV]" type="Real" group="Ratings" helpmode="Append" content_type="Literal" intent="Input" dim="1" animate="false" unit="" min="0" max="1E+308">
            <value><![CDATA[66]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Line-to-line RMS]]></help>
          </parameter>
          <parameter name="f_sup" desc="Frequency support" type="Choice" group="" helpmode="Append" animate="false">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Enable or dissable frequency support]]></help>
            <choice><![CDATA[1 = P/f droop]]></choice>
            <choice><![CDATA[0 = No. Constant P]]></choice>
          </parameter>
          <parameter name="v_sup" desc="Voltage support" type="Choice" group="" helpmode="Append" animate="false">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Enable or disable AC voltage control]]></help>
            <choice><![CDATA[1 = V/Q droop]]></choice>
            <choice><![CDATA[0 = No. Constant Q]]></choice>
          </parameter>
          <parameter name="q_ref" desc="Reactive power [pu]" type="Real" group="Setpoints" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="-1" max="1">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[true]]></vis>
            <help><![CDATA[Per unit]]></help>
          </parameter>
          <parameter name="v_ref" desc="AC voltage magnitude [pu]" type="Real" group="Setpoints" helpmode="Append" content_type="Variable" intent="Input" dim="1" animate="false" unit="" min="0" max="1.2">
            <value><![CDATA[1]]></value>
            <cond><![CDATA[true]]></cond>
            <vis><![CDATA[v_sup == 1]]></vis>
