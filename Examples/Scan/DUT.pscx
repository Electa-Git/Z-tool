    <Definition classid="UserCmpDefn" name="Outter_loop" group="" url="" version="" build="" crc="77205197" instances="0" key="" view="false" date="1662130251" id="1295487276">
      <paramlist name="">
        <param name="Description" value="" />
      </paramlist>
      <form name="" w="500" h="400" splitter="60" category-width="180" commentlines="4" help-width="490">
        <category name="General" visible="true" splitter="60">
          <cond />
          <parameter desc="Active power [pu]" name="Pref" group="Setpoints" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[Pmode ==1]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Frequency [Hz]" name="fref" group="Setpoints" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[50]]></value>
            <cond><![CDATA[(Pmode == 1)]]></cond>
            <help />
            <vis />
          </parameter>
