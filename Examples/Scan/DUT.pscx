    <Definition classid="UserCmpDefn" name="Inner_Loop" group="" url="" version="" build="" crc="24680932" instances="0" key="" view="false" date="1662130252" id="1757966787">
      <paramlist name="">
        <param name="Description" value="" />
      </paramlist>
      <form name="" w="320" h="400" splitter="60">
        <category name="Configuration" visible="true">
          <cond />
          <parameter desc="Omega [rad/s]" name="w" group="" unit="" min="-1E+308" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[314.15927]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Base impedance [Ohms]" name="Zb" group="General" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Converter's voltage [kV]" name="Vbase" group="" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Voltage LPF time constant [s]" name="Tf_v" group="" unit="" min="0" max="1E+308" content_type="Literal" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1e-4]]></value>
            <cond />
            <help><![CDATA[Time constant of the low pass filter for the voltage feed-forward]]></help>
            <vis />
          </parameter>
          <parameter desc="Current LPF time constant [s]" name="Tf_i" group="" unit="" min="0" max="1E+308" content_type="Literal" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1e-5]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Manual or automatic" name="tuning_auto" group="Tuning" type="Choice" helpmode="Append" animate="false">
            <value><![CDATA[0]]></value>
            <cond />
            <help />
            <vis />
            <choice><![CDATA[0 = Manual]]></choice>
            <choice><![CDATA[1 = Auto]]></choice>
          </parameter>
          <parameter desc="Time constant of the delay LPF [s]" name="Tde" group="General" unit="" min="0" max="1E+308" content_type="Literal" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1e-6]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Desired time constant [s]" name="tau" group="Tuning" unit="" min="1E-10" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[0.001]]></value>
            <cond><![CDATA[tuning_auto == 1]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Proportional gain" name="kp" group="Tuning" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1]]></value>
            <cond><![CDATA[tuning_auto == 0]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Integral gain" name="ki" group="Tuning" unit="" min="-1E+308" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1]]></value>
            <cond><![CDATA[tuning_auto == 0]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Converter side reactor resistance [Ohms]" name="Rf" group="Tuning" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[tuning_auto == 1]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Grid side reactor resistance [Ohms]" name="Rt" group="Tuning" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[0]]></value>
            <cond><![CDATA[tuning_auto == 1]]></cond>
            <help />
            <vis />
          </parameter>
          <parameter desc="Converter side inductance  [H]" name="Lf" group="" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[1]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
          <parameter desc="Grid side inductance [H]" name="Lt" group="" unit="" min="0" max="1E+308" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1" animate="false">
            <value><![CDATA[0]]></value>
            <cond />
            <help />
            <vis />
          </parameter>
        </category>
      </form>
